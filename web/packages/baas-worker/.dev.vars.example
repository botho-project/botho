# Local development secrets for `wrangler dev` (#458 §2, §7).
#
# Copy to `.dev.vars` (gitignored) and fill in your Stripe TEST values.
# NEVER commit real keys. In production these are set via `wrangler secret put`,
# not from this file.

# Stripe TEST secret key. Get it from the Stripe dashboard (test mode).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# The recurring $50/mo Price id, created once (see README "Stripe setup").
STRIPE_PRICE_ID=price_REPLACE_ME

# Stripe webhook signing secret (whsec_...). REQUIRED for /webhook — every
# delivery's Stripe-Signature is HMAC-verified against this over the RAW body,
# with a 5-minute timestamp tolerance, before any provision/teardown (#458 §5).
# `stripe listen --forward-to localhost:8787/webhook` prints a local whsec_ for
# testing; the dashboard issues the production one. NEVER commit a real value.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Redirect URLs for local dev (the Pages dev server / preview).
CHECKOUT_SUCCESS_URL=http://localhost:5173/node/success
CHECKOUT_CANCEL_URL=http://localhost:5173/node

# --- status page / magic-link lookup (P6.3, #458 §4/§6) -------------------
# HMAC secret for magic-link status tokens. REQUIRED for /status and /portal.
# Generate any long random string (e.g. `openssl rand -hex 32`). The token a
# returning user presents is signed with this and binds to ONE Stripe customer,
# so they can only ever see their own node. NEVER commit a real value.
STATUS_LINK_SECRET=REPLACE_ME_WITH_RANDOM_HEX
# Wallet origin used to build the "open in wallet" deep link (#458 §3 step 5).
WALLET_BASE_URL=http://localhost:5173
# Where Stripe returns the user after they close the Customer Portal.
PORTAL_RETURN_URL=http://localhost:5173/node/status

# Browser origins allowed to call /checkout, /status, /portal during local dev.
ALLOWED_ORIGINS=http://localhost:5173

# --- provisioner secrets (#502, #458 §3/§5) -------------------------------
# A DEDICATED, tightly-scoped provisioner IAM user (NOT botho-deploy). The IAM
# policy hardening (tag/type/region conditions) is SEC (#508); the code here
# already enforces the region/type allowlists + idempotency. NEVER commit real
# keys — these placeholders are for local `wrangler dev` only.
AWS_ACCESS_KEY_ID=AKIA_REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
# AWS_SESSION_TOKEN=                # only if using temporary STS credentials

# Cloudflare Zone:DNS:Edit token + the testnet.botho.io zone id.
CF_DNS_API_TOKEN=cf_dns_REPLACE_ME
CF_DNS_ZONE_ID=REPLACE_ME

# Bootstrap binary the node downloads at boot (optional locally).
BOTHO_BINARY_URL=https://example.com/botho-aarch64
BOTHO_BINARY_SHA256=REPLACE_ME
